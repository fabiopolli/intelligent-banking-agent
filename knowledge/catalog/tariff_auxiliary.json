    {"rule_id":"rule-multiple-card-legacy","page_number":23,"rule_code":"7","text":"O Cartão Múltiplo Visa indicado é exclusivo para contas abertas originalmente no Unibanco.","status":"published","reviewed_at":"2026-07-21"},
