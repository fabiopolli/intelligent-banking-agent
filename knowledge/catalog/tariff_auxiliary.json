  "rules": [
    {"rule_id":"rule-package-overage","page_number":22,"rule_code":"PACKAGE_OVERAGE","text":"Serviços incluídos no pacote são cobrados individualmente somente após o cliente ultrapassar a quantidade prevista na composição.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-personnalite-only","page_number":22,"rule_code":"P","text":"Os serviços marcados com P são válidos somente para clientes Itaú Personnalité.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-investment-custody-b3-variable","page_number":22,"rule_code":"D","text":"À custódia indicada soma-se taxa variável calculada conforme o valor da carteira e a tabela vigente da B3.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-bovespa-fix-only","page_number":22,"rule_code":"E","text":"A taxa indicada é cobrada apenas para debêntures negociadas no sistema Bovespa Fix.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-investment-operation-b3-variable","page_number":22,"rule_code":"P2","text":"À corretagem soma-se taxa variável calculada sobre o valor financeiro da operação conforme a tabela vigente da B3.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-electronic-account","page_number":7,"rule_code":"ELECTRONIC_ACCOUNT","text":"Nas contas exclusivamente eletrônicas, tarifas indicadas para canais eletrônicos não podem ser cobradas quando a tabela assim determina.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-ccf-limit","page_number":8,"rule_code":"2","text":"A exclusão de CCF é limitada a dez cheques por ocorrência e pode incluir reembolso da taxa cobrada pelo Banco Central.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-cheque-event","page_number":8,"rule_code":"3","text":"Evento é o conjunto de cheques, de uma a vinte folhas do mesmo talão, com oposição ou cancelamento solicitado no mesmo dia.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-banco24horas-terminal","page_number":8,"rule_code":"4","text":"Saque terminal inclui caixas eletrônicos Itaú e caixas eletrônicos da rede Banco24Horas.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-card-payment-charges","page_number":8,"rule_code":"B","text":"Pagamento de contas com função crédito está sujeito à cobrança de encargos, incluindo juros e tributos.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-card-replacement","page_number":23,"rule_code":"1","text":"A segunda via de cartão é cobrada quando a reposição decorre de perda, roubo, furto, dano ou outro motivo não imputável ao emissor.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-cheque-home-delivery","page_number":23,"rule_code":"2","text":"A entrega de talões em domicílio ou pelos Correios depende da disponibilidade do serviço para a agência.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-cheque-statement-month","page_number":23,"rule_code":"3","text":"Na identificação da entrega do talão, MM representa o mês e AA o ano da prestação do serviço.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-cheque-copy-physical","page_number":23,"rule_code":"4","text":"A cópia de folha de cheque é cobrada nos casos de impressão física.","status":"published","reviewed_at":"2026-07-21"},
    {"rule_id":"rule-registration-once","page_number":23,"rule_code":"5","text":"A tarifa de cadastro por CNPJ da holding Itaú ocorre uma única vez por CPF.","status":"published","reviewed_at":"2026-07-21"},
