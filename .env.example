APP_NAME=intelligent-banking-agent
API_PREFIX=/v1
HITL_PIX_THRESHOLD=5000
CARD_LIMIT_MIN_CREDIT_SCORE=650
DEFAULT_USER_ROLE=customer
KNOWLEDGE_STORE=local
AUDIT_STORE=memory
DATABASE_URL=postgresql://itau:itau@localhost:5432/itau_agent
POSTGRES_HOST_PORT=5432
KNOWLEDGE_EMBEDDING_DIMENSIONS=64
LLM_GROUNDED_FAQ_ENABLED=true
LLM_PROVIDER=openai
LLM_FALLBACK_PROVIDER=docker_model_runner
LLM_MODEL=gpt-5.4
LLM_REASONING_EFFORT=low
AGENTIC_PLANNER_ENABLED=true
PROMPT_ROOT=prompts
PROMPT_PROFILE=banking-v1
OPENAI_API_KEY=
DEMO_AUTH_REQUIRED=true
DEMO_CUSTOMER_TOKEN=demo-customer-123-token
DEMO_MANAGER_TOKEN=demo-manager-token
DEMO_ADMIN_TOKEN=demo-admin-token
DOCKER_MODEL_RUNNER_BASE_URL=http://localhost:12434/engines/v1
# Docker Compose uses COMPOSE_DOCKER_MODEL_RUNNER_BASE_URL so local venv can keep localhost.
# COMPOSE_DOCKER_MODEL_RUNNER_BASE_URL=http://host.docker.internal:12434/engines/v1
DOCKER_MODEL_RUNNER_MODEL=gemma4:latest
INTERNAL_SYSTEMS_TRANSPORT=local
MCP_CLIENT_URL=http://localhost:8600/mcp
